{
  "$schema": "http://json.schemastore.org/proxies",
  "proxies": {
    "root_to_home": {
      "matchCondition": {
        "route": "/",
        "methods": ["GET"]
      },
      "responseOverrides": {
        "response.statusCode": "302",
        "response.headers.Location": "/home"
      }
    }
  }
}
